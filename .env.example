# App
APP_ENV=development
APP_NAME=personal-finance-manager

# Frontend
FRONTEND_HOST=localhost
FRONTEND_PORT=5000
NEXT_PUBLIC_API_BASE_URL=http://localhost:9999

# Backend
BACKEND_HOST=localhost
BACKEND_PORT=9999
BACKEND_RELOAD=true
SECRET_KEY=change-me-in-local-env

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=personal_finance_sol
DATABASE_USER=postgres
DATABASE_PASSWORD=change-me
DATABASE_SSL_MODE=disable

# Import settings
MAX_UPLOAD_MB=25
UPLOAD_STORAGE_DIR=backend/storage/imports
