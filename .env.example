# App
APP_ENV=development
APP_NAME=personal-finance-manager

# Frontend
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5000
# Comma-separated browser origins allowed to call the backend.
# Set this to the remote frontend origin when deploying without a reverse proxy.
CORS_ORIGINS=http://127.0.0.1:5000

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=9999
BACKEND_RELOAD=true
API_ROOT_PATH=
COOKIE_SECURE=false
SECRET_KEY=change-me-in-local-env

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=personal_finance_sol
DATABASE_USER=postgres
DATABASE_PASSWORD=change-me
DATABASE_SSL_MODE=disable

# Import settings
MAX_UPLOAD_MB=25
UPLOAD_STORAGE_DIR=backend/storage/imports
